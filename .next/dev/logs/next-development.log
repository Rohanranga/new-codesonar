s.name,\n          avatar: users.avatar,\n        },\n      })\n      .from(recipes)\n      .leftJoin(users, eq(recipes.authorId, users.id))\n      .where(eq(recipes.slug, slug))\n      .limit(1);\n\n    if (!recipe.length) {\n      return NextResponse.json(\n        { error: \"Recipe not found\" },\n        { status: 404 }\n      );\n    }\n\n    const recipeData = {\n      ...recipe[0].recipe,\n      author: recipe[0].author,\n    };\n\n    return NextResponse.json({\n      success: true,\n      data: {\n        recipe: recipeData,\n      },\n    });\n  } catch (error) {\n    console.error(\"Failed to fetch recipe:\", error);\n    return NextResponse.json(\n      { error: \"Internal server error\" },\n      { status: 500 }\n    );\n  }\n}\n","explanation":"## 📄 What is this file?\n\nThis is an **API Route** - it handles requests from the frontend (like when a user submits a form) and sends back data or performs actions on the server.\n\n## 🎯 What does it do?\n\n## 📦 What does it depend on?\n\nThis file imports code from other places:\n- **`next/server`** - An external library installed via npm\n- **`drizzle-orm`** - An external library installed via npm\n- **`@/db/drizzle`** - Another file in this project\n- **`@/db/schema`** - Another file in this project\n\n## 🔧 How does it work?\n\nThis is a **medium-sized file** (53 lines) with moderate complexity. It likely handles a complete feature or component.\n\n⚠️ This file uses **async/await** for handling asynchronous operations (like API calls). This means some functions wait for data to arrive before continuing.\n\n✅ Good! This file includes **error handling** (try/catch blocks) to gracefully handle failures instead of crashing.\n\n","keyFeatures":["See explanation"],"language":"ts","lines":53,"path":"src/app/api/v1/recipes/[slug]/route.ts","preview":"import { NextRequest, NextResponse } from \"next/server\";\nimport { eq } from \"drizzle-orm\";\nimport { db } from \"@/db/drizzle\";\nimport { recipes, users } from \